# WICHTIG: Diese Datei wird committet (zeigt nur Struktur).
# Echte Werte NIEMALS hier eintragen!
#
# Alle Werte als GitHub Codespaces Secrets hinterlegen:
#   Repository → Settings → Secrets and variables → Codespaces
#   → New repository secret
#
# Nach dem Setzen der Secrets: Codespace neu starten
#   (Rebuild Container)
# ============================================================

DATABRICKS_HOST=https://dbc-XXXXXXXX-XXXX.cloud.databricks.com
DATABRICKS_TOKEN=dapi_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/XXXXXXXXXXXXXXXX
DATABRICKS_CATALOG=main
DATABRICKS_SCHEMA=polar
