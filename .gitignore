# ============================================================
# Polar Health Analytics – .gitignore
# KRITISCH: Schützt alle Gesundheitsdaten & Credentials
# ============================================================

# --- Credentials & Konfiguration ---
.env
.databricks_config.json

# --- Gesundheitsdaten – ALLE Formate und Ordner ---
input/
archive/
data/
*.zip
*.json
*.gpx
*.tcx
*.fit
*.data
*.db

# --- Python ---
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb_checkpoints

# --- Codespace ---
.devcontainer/secrets/

# --- Betriebssystem ---
.DS_Store
Thumbs.db
*.swp
*~

# --- Output (lokal generiert, nicht committen) ---
output/*.html
output/*.png
output/*.pdf
